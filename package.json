{
  "name": "qistemplates",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=qitemplates-cli",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "bun": ">=1.3.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@types/node": "^24.0.0",
    "turbo": "^2.5.8",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2"
  }
}
