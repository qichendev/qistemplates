{
  "name": "qitemplates-cli",
  "version": "0.1.1",
  "description": "CLI for creating projects from qistemplates templates.",
  "type": "module",
  "bin": {
    "qi": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup src/cli.ts --config ../../tsup.config.ts",
    "dev": "bun run src/cli.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "qitemplates-core": "^0.1.0",
    "@clack/prompts": "^0.10.1",
    "commander": "^14.0.0"
  }
}
